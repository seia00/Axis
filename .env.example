# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is gitignored for your protection.

# Database (Neon PostgreSQL — neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-secret"

# Supabase (app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (resend.com → API Keys)
RESEND_API_KEY="re_QV7abLXe_JUduQ6XGfqPuuZQh4az3VXqi"
EMAIL_FROM="AxisJP13@gmail.com"

# Claude / Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-your-key"
