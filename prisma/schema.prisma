generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ORG_LEADER
  ADMIN
}

enum OrgTier {
  MEMBER
  VERIFIED
  PARTNER
}

enum MergeType {
  FULL_MERGER
  PROGRAMMATIC_MERGER
  ABSORB_REBRAND
  COLLABORATIVE_ALLIANCE
}

enum MergeStatus {
  INTAKE
  ASSESSMENT
  DESIGN
  INTEGRATION
  COMPLETED
  REJECTED
}

enum VentureStatus {
  PENDING
  ACCEPTED
  REJECTED
  LAUNCHED
}

enum ResourceCategory {
  LEGAL
  FINANCIAL
  DESIGN
  COMMUNICATIONS
  SUCCESSION
  OTHER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  image           String?
  role            Role      @default(STUDENT)
  school          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  banned          Boolean   @default(false)
  interests       String[]
  skills          String[]
  goals           String[]
  experienceLevel String    @default("beginner")
  headline        String?
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  bio             String?   @db.Text
  location        String?
  username        String?   @unique
  // Social links
  twitterHandle   String?
  instagramHandle String?
  linkedinUrl     String?
  websiteUrl      String?

  accounts           Account[]
  sessions           Session[]
  reviews            Review[]
  orgsLed            Organization[]    @relation("OrgLeader")
  ventures           Venture[]
  mergeMessages      MergeMessage[]
  activities         Activity[]
  savedOpportunities SavedOpportunity[]
  projects           Project[]
  projectMembers     ProjectMember[]
  applications       Application[]
  calendarEvents     CalendarEvent[]
  matchesFrom        Match[]           @relation("MatchesFrom")
}

model Organization {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  mission         String   @db.Text
  activitySummary String?  @db.Text
  focusArea       String[]
  activityType    String[]
  location        String
  isNational      Boolean  @default(false)
  schoolLevel     String[]
  tier            OrgTier  @default(MEMBER)
  verified        Boolean  @default(false)
  logoUrl         String?
  bannerUrl       String?
  website         String?
  instagram       String?
  twitter         String?
  memberCount     Int?
  leaderId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  profileViews    Int      @default(0)

  leader        User           @relation("OrgLeader", fields: [leaderId], references: [id])
  events        Event[]
  reviews       Review[]
  mergesInitiated MergeRequest[] @relation("InitiatorOrg")
  mergesTargeted  MergeRequest[] @relation("TargetOrg")
  teamMembers   OrgTeamMember[]
  verificationApplication VerificationApplication?
}

model OrgTeamMember {
  id     String @id @default(cuid())
  orgId  String
  userId String
  role   String @default("member")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model Event {
  id               String    @id @default(cuid())
  orgId            String
  title            String
  description      String    @db.Text
  date             DateTime
  endDate          DateTime?
  location         String?
  isOnline         Boolean   @default(false)
  registrationLink String?
  focusArea        String[]
  createdAt        DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  rating    Int
  content   String   @db.Text
  createdAt DateTime @default(now())
  removed   Boolean  @default(false)
  removedBy String?

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model MergeRequest {
  id              String      @id @default(cuid())
  initiatorOrgId  String
  targetOrgId     String?
  mergeType       MergeType
  status          MergeStatus @default(INTAKE)
  description     String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  initiatorOrg Organization   @relation("InitiatorOrg", fields: [initiatorOrgId], references: [id])
  targetOrg    Organization?  @relation("TargetOrg", fields: [targetOrgId], references: [id])
  messages     MergeMessage[]
}

model MergeMessage {
  id             String   @id @default(cuid())
  mergeRequestId String
  senderId       String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  mergeRequest MergeRequest @relation(fields: [mergeRequestId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
}

model Resource {
  id            String           @id @default(cuid())
  category      ResourceCategory
  title         String
  description   String?
  fileUrl       String
  fileType      String?
  downloadCount Int              @default(0)
  uploadedAt    DateTime         @default(now())
  uploadedBy    String?
}

model Venture {
  id              String        @id @default(cuid())
  name            String
  leaderId        String
  status          VentureStatus @default(PENDING)
  applicationData Json
  cohort          String?
  focusArea       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  leader     User               @relation(fields: [leaderId], references: [id])
  milestones VentureMilestone[]
  forumPosts ForumPost[]
}

model VentureMilestone {
  id          String    @id @default(cuid())
  ventureId   String
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  completedAt DateTime?

  venture Venture @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model ForumPost {
  id        String   @id @default(cuid())
  ventureId String
  authorId  String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venture Venture @relation(fields: [ventureId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
  confirmed    Boolean  @default(false)
}

model VerificationApplication {
  id          String    @id @default(cuid())
  orgId       String    @unique
  targetTier  OrgTier
  notes       String?   @db.Text
  status      String    @default("pending")
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model ImpactStat {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Match {
  id         String   @id @default(cuid())
  fromUserId String
  fromUser   User     @relation("MatchesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  type       String
  reason     String   @db.Text
  score      Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model Activity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  type          String
  organization  String?
  role          String?
  description   String?   @db.Text
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean   @default(false)
  hoursPerWeek  Int?
  peopleReached Int?
  awards        String[]
  proofUrl      String?
  tags          String[]
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Opportunity {
  id           String             @id @default(cuid())
  title        String
  type         String
  organization String
  description  String             @db.Text
  eligibility  String?            @db.Text
  location     String?
  isRemote     Boolean            @default(false)
  url          String?
  deadline     DateTime?
  startDate    DateTime?
  endDate      DateTime?
  tags         String[]
  regions      String[]
  isVerified   Boolean            @default(false)
  verifiedAt   DateTime?
  savedCount   Int                @default(0)
  viewCount    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  savedBy      SavedOpportunity[]
}

model SavedOpportunity {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  status        String      @default("saved")
  notes         String?
  createdAt     DateTime    @default(now())
  @@unique([userId, opportunityId])
}

model Project {
  id             String          @id @default(cuid())
  creatorId      String
  creator        User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title          String
  tagline        String?
  description    String          @db.Text
  stage          String          @default("idea")
  category       String
  tags           String[]
  logoUrl        String?
  coverUrl       String?
  websiteUrl     String?
  isVenture      Boolean         @default(false)
  ventureStage   String?
  mentorAssigned String?
  appliedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  roles          Role2[]
  members        ProjectMember[]
  applications   Application[]
  milestones     Milestone[]
}

model Role2 {
  id           String        @id @default(cuid())
  projectId    String
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  skills       String[]
  commitment   String?
  isFilled     Boolean       @default(false)
  applications Application[]

  @@map("Role2")
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  joinedAt  DateTime @default(now())
  @@unique([userId, projectId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId    String?
  role      Role2?   @relation(fields: [roleId], references: [id])
  message   String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model CalendarEvent {
  id            String    @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  endDate       DateTime?
  type          String
  url           String?
  color         String?
  opportunityId String?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isGlobal      Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model ProjectResource {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  category      String
  type          String
  fileUrl       String?
  externalUrl   String?
  tags          String[]
  region        String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
}
